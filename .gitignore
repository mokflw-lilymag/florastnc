# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
pack/wrap/next-standalone/.next/

# production
/build

# misc
.DS_Store
*.pem

# Cursor MCP (Personal Access Token — 커밋 금지)
.cursor/mcp.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# temporary scratch scripts
/scratch/
scratch/

# migration dumps & Vercel env backups (secrets)
scripts/backups/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor / Android local
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
*.apk
*.aab

# Supabase CLI local cache
supabase/.temp/

# i18n MT cache (machine-specific; safe to delete)
scripts/data/tenant-flow-mt-cache.json
scripts/data/dashboard-eu-mt-cache.json
scripts/.dashboard-ja-lingva-cache.json

.trigger
dist/
electron/engine/build/
.vercel

# Binary build artifacts (exe) — 배포용 public/downloads 제외하고 무시
bridge-app/*.exe
bridge-standalone-build/**/*.exe
bridge-standalone-build/*.exe
bridge-manager/*.exe
electron/engine/**/*.exe
# public/downloads/*.exe 는 배포용이므로 트래킹 유지
