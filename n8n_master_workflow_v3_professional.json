    "Platform_Switch": {
      "main": [
        [{ "node": "Node_Instagram", "type": "main", "index": 0 }],
        [{ "node": "Node_Facebook", "type": "main", "index": 0 }],
        [{ "node": "Node_TikTok", "type": "main", "index": 0 }],
        [{ "node": "Node_YouTube_Shorts", "type": "main", "index": 0 }],
        [{ "node": "Node_Google_Blogger", "type": "main", "index": 0 }],
        [{ "node": "Node_Naver_Blog", "type": "main", "index": 0 }]
      ]
    },
    "Node_Instagram": { "main": [[{ "node": "Update_Post_Status", "type": "main", "index": 0 }]] },
    "Node_Facebook": { "main": [[{ "node": "Update_Post_Status", "type": "main", "index": 0 }]] },
    "Node_TikTok": { "main": [[{ "node": "Update_Post_Status", "type": "main", "index": 0 }]] },
    "Node_YouTube_Shorts": { "main": [[{ "node": "Update_Post_Status", "type": "main", "index": 0 }]] },
    "Node_Google_Blogger": { "main": [[{ "node": "Update_Post_Status", "type": "main", "index": 0 }]] },
    "Node_Naver_Blog": { "main": [[{ "node": "Update_Post_Status", "type": "main", "index": 0 }]] }
  }
